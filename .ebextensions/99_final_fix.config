container_commands:
  01_storage_permission:
    command: "mkdir -p storage && chmod -R 775 storage"
    ignoreErrors: true
    
  02_set_permissions:
    command: "chown -R webapp:webapp storage"
    ignoreErrors: true

  03_fix_symlink:
    command: "ln -sf /var/app/current/public /var/www/html"
    ignoreErrors: true

  04_fix_public:
    command: "chmod -R 755 public && chown -R webapp:webapp public"
    ignoreErrors: true

  05_fix_cache:
    command: "mkdir -p bootstrap/cache && chmod -R 775 bootstrap/cache && chown -R webapp:webapp bootstrap/cache"
    ignoreErrors: true

  06_fix_index:
    command: |
      if [ ! -f public/index.php ]; then
        cat > public/index.php << 'EOF'
      <?php
      use Illuminate\Contracts\Http\Kernel;
      use Illuminate\Http\Request;
      define('LARAVEL_START', microtime(true));
      if (file_exists($maintenance = __DIR__.'/../storage/framework/maintenance.php')) {
          require $maintenance;
      }
      require __DIR__.'/../vendor/autoload.php';
      $app = require_once __DIR__.'/../bootstrap/app.php';
      $kernel = $app->make(Kernel::class);
      $response = $kernel->handle($request = Request::capture())->send();
      $kernel->terminate($request, $response);
      EOF
      fi
    ignoreErrors: true

  07_restart_httpd:
    command: "systemctl restart httpd"
    ignoreErrors: true

  08_restart_php:
    command: "systemctl restart php-fpm"
    ignoreErrors: true
