commands:
  01_install_dependencies:
    command: "cd /var/app/current && composer install --no-dev --optimize-autoloader"
    ignoreErrors: true
  02_set_permissions:
    command: "sudo chmod -R 777 /var/app/current/storage /var/app/current/bootstrap/cache"
  03_set_owner:
    command: "sudo chown -R webapp:webapp /var/app/current/storage /var/app/current/bootstrap/cache"
  04_clear_cache:
    command: "cd /var/app/current && php artisan optimize:clear"
    ignoreErrors: true
  05_migrate:
    command: "cd /var/app/current && php artisan migrate --force"
    leader_only: true
    ignoreErrors: true
  06_config_cache:
    command: "cd /var/app/current && php artisan config:cache"
    ignoreErrors: true
  07_route_cache:
    command: "cd /var/app/current && php artisan route:cache"
    ignoreErrors: true
  08_view_cache:
    command: "cd /var/app/current && php artisan view:cache"
    ignoreErrors: true
  09_storage_link:
    command: "cd /var/app/current && php artisan storage:link"
    ignoreErrors: true
